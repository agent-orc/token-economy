{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-orchestrator.dev/token-economy/document-text-corpus.schema.json",
  "title": "Token Economy document-to-text corpus",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "cases"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "invocationTimeoutSeconds": { "type": "integer", "minimum": 1, "default": 300 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "documentType", "documentPath", "requiredFragments"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "documentType": { "enum": ["Pdf", "Word", "Spreadsheet", "Presentation"] },
          "documentPath": { "type": "string", "minLength": 1 },
          "requiredFragments": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "forbiddenFragments": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "note": { "type": "string" }
        }
      }
    }
  }
}
