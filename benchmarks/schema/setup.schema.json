{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-orchestrator.dev/token-economy/benchmark-setup.schema.json",
  "title": "Token Economy benchmark setup",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "task", "variants", "successCriteria"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "task": { "type": "object", "additionalProperties": false, "required": ["prompt", "seedWorkspace"], "properties": { "prompt": { "type": "string", "minLength": 1 }, "seedWorkspace": { "type": "string", "minLength": 1 }, "responseFile": { "type": "string", "minLength": 1 } } },
    "variants": { "type": "array", "minItems": 2, "items": { "type": "object", "additionalProperties": false, "required": ["id", "model"], "properties": { "id": { "type": "string", "minLength": 1 }, "model": { "type": "string", "minLength": 1 }, "thinkingLevel": { "type": "string" } } } },
    "repetitions": { "type": "integer", "minimum": 1, "default": 1 },
    "invocationTimeoutSeconds": { "type": "integer", "minimum": 1, "default": 300 },
    "successCriteria": { "type": "object", "additionalProperties": false, "required": ["command"], "properties": { "command": { "type": "string", "minLength": 1 }, "arguments": { "type": "array", "items": { "type": "string" } }, "expectedExitCode": { "type": "integer", "default": 0 }, "timeoutSeconds": { "type": "integer", "minimum": 1, "default": 120 } } },
    "costCaps": { "type": "object", "additionalProperties": false, "properties": { "maxTotalTokensPerInvocation": { "type": "integer", "minimum": 1 }, "maxUsdPerInvocation": { "type": "number", "exclusiveMinimum": 0 } } }
  }
}
